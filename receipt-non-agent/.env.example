# Twilio WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# SMTP (Gmail example — use App Password, not your login password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_app_password
REIMBURSEMENT_EMAIL=finance@example.com

# Google Sheets — file path locally, or paste entire JSON string for Render
GOOGLE_SERVICE_ACCOUNT_JSON=service-account.json
GOOGLE_SHEET_ID=                          # leave empty to auto-create
GOOGLE_SHEET_NAME=Reimbursements
GOOGLE_SHEET_SHARE_EMAIL=you@gmail.com    # who gets access to auto-created sheets

# Storage
RECEIPTS_DIR=receipts

# Server
HOST=0.0.0.0
PORT=8000
